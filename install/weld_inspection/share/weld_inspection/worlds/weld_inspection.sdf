        <visual name="lens"><pose>0 0 0.038 0 0 0</pose><geometry><cylinder><radius>0.014</radius><length>0.010</length></cylinder></geometry><material><ambient>0.02 0.04 0.08 1</ambient><diffuse>0.02 0.04 0.08 1</diffuse><specular>1 1 1 1</specular></material></visual>
        <visual name="led_b"><pose>0.045 0.027 0.033 0 0 0</pose><geometry><sphere><radius>0.005</radius></sphere></geometry><material><ambient>0.12 0.28 0.75 1</ambient><diffuse>0.14 0.32 0.80 1</diffuse><emissive>0.06 0.14 0.38 1</emissive></material></visual>
        <sensor name="return_belt_camera" type="camera">
          <always_on>1</always_on><update_rate>5</update_rate>
          <topic>/return_belt_camera/image_raw</topic>
          <camera>
            <horizontal_fov>0.85</horizontal_fov>
            <image><width>320</width><height>240</height><format>R8G8B8</format></image>
            <clip><near>0.05</near><far>8.0</far></clip>
          </camera>
        </sensor>
      </link>
    </model>

    <!-- U-turn connector at X=-6.5, bridges return belt (Y=-1.61) to input belt (Y=0) -->
    <model name="uturn_connector"><static>true</static><pose>-6.5 -0.80 0.820 0 0 0</pose>
      <link name="plate">
        <visual name="v"><geometry><box><size>0.42 1.62 0.012</size></box></geometry><material><ambient>0.40 0.42 0.44 1</ambient><diffuse>0.44 0.46 0.48 1</diffuse><specular>0.32 0.32 0.32 1</specular></material></visual>
        <collision name="c"><geometry><box><size>0.42 1.62 0.012</size></box></geometry><surface><friction><ode><mu>0.7</mu><mu2>0.7</mu2></ode></friction></surface></collision>
      </link>
      <link name="support"><pose>0 0 -0.04 0 0 0</pose>
        <visual name="v"><geometry><box><size>0.42 1.62 0.068</size></box></geometry><material><ambient>0.34 0.36 0.38 1</ambient><diffuse>0.38 0.40 0.42 1</diffuse><specular>0.22 0.22 0.22 1</specular></material></visual>
        <collision name="c"><geometry><box><size>0.42 1.62 0.068</size></box></geometry></collision>
      </link>
