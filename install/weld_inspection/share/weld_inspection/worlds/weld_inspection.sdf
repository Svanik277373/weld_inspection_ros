        <collision name="c"><geometry><box><size>0.44 0.018 0.060</size></box></geometry></collision>
      </link>
    </model>

    <!-- ═══════════════════════════════════════════════════════════════
         FLOOR MARKINGS, BOLLARDS, PROPS
    ══════════════════════════════════════════════════════════════ -->

    <!-- Inspection zone floor border -->
