<?xml version="1.0" ?>
<!--
╔══════════════════════════════════════════════════════════════════════╗
║  WELD INSPECTION FACTORY — Complete Industrial Cell v4               ║
║  ─────────────────────────────────────────────────────────────────── ║
║  FLOW:                                                               ║
║  Input Belt → Inspection Belt → Diverter → Good Belt → Good Bin     ║
║                                         → Reject Belt → Rework Zone ║
║                                                       → Return Belt  ║
║                                                       → Input Belt   ║
║  ─────────────────────────────────────────────────────────────────── ║
║  BELT SURFACES: all at Z=0.820 (consistent throughout)              ║
║  CAMERAS:       one overhead per segment, pointing straight down     ║
║  ROBOT ARM:     continuous animated welding motion at rework zone    ║
║  ANIMATIONS:    belt conveyor plugins on every belt                  ║
╚══════════════════════════════════════════════════════════════════════╝

  X layout (Y=0 centreline):
    Input belt:      X=-6.5 → X=-3.0   (length 3.5m)
    Transfer plate:  X=-3.0 (junction)
    Main belt:       X=-3.0 → X=2.5    (length 5.5m)
    Good belt:       X=2.5  → X=5.2    (length 2.7m)
    Good bin:        X=5.5
    Diverter gate:   X=2.02

  Y layout (X=2.5 column):
    Junction:        Y=0
    Reject belt:     Y=0    → Y=-5.5   (length 5.5m)
    Rework station:  Y=-6.2

  Return path (parallel to main, offset Y=-1.5):
    Return belt:     X=-6.5 → X=2.5   at Y=-1.5
    Input U-turn:    at X=-6.5, bridging Y=-1.5 → Y=0
-->
<sdf version="1.9">
  <world name="weld_inspection_world">

    <!-- ══ PHYSICS ═══════════════════════════════════════════════════ -->
    <physics name="1ms" type="ignored">
      <max_step_size>0.001</max_step_size>
      <real_time_factor>1.0</real_time_factor>
    </physics>
    <plugin filename="gz-sim-physics-system"           name="gz::sim::systems::Physics"/>
    <plugin filename="gz-sim-sensors-system"           name="gz::sim::systems::Sensors">
      <render_engine>ogre2</render_engine>
    </plugin>
    <plugin filename="gz-sim-scene-broadcaster-system" name="gz::sim::systems::SceneBroadcaster"/>
    <plugin filename="gz-sim-user-commands-system"     name="gz::sim::systems::UserCommands"/>

    <!-- ══ SCENE ══════════════════════════════════════════════════════ -->
    <scene>
      <ambient>0.52 0.52 0.54 1</ambient>
      <background>0.68 0.69 0.71 1</background>
      <shadows>false</shadows>
    </scene>

    <!-- ══ LIGHTING — uniform industrial, no harsh shadows ═══════════ -->
    <light type="directional" name="main_overhead">
      <cast_shadows>false</cast_shadows>
      <pose>0 0 10 0 0 0</pose>
      <diffuse>0.78 0.78 0.76 1</diffuse>
      <specular>0.08 0.08 0.07 1</specular>
      <direction>0.0 0.05 -1.0</direction>
    </light>
    <light type="directional" name="fill">
      <cast_shadows>false</cast_shadows>
      <pose>0 0 6 0 0 0</pose>
      <diffuse>0.42 0.42 0.44 1</diffuse>
      <specular>0.03 0.03 0.03 1</specular>
      <direction>0.10 -0.10 -0.98</direction>
    </light>
    <!-- Inspection spot — mounted on camera gantry -->
    <light type="spot" name="inspection_spot">
      <cast_shadows>false</cast_shadows>
      <pose>0 0 2.15 0 0 0</pose>
      <diffuse>1.0 1.0 1.0 1</diffuse>
      <specular>0.50 0.50 0.50 1</specular>
      <direction>0 0 -1</direction>
      <attenuation><range>3.5</range><constant>0.30</constant><linear>0.08</linear><quadratic>0.01</quadratic></attenuation>
      <spot><inner_angle>0.38</inner_angle><outer_angle>0.70</outer_angle><falloff>1.0</falloff></spot>
    </light>
    <!-- Rework zone light -->
    <light type="spot" name="rework_spot">
      <cast_shadows>false</cast_shadows>
      <pose>2.5 -6.2 2.5 0 0 0</pose>
      <diffuse>1.0 0.92 0.82 1</diffuse>
      <specular>0.40 0.36 0.30 1</specular>
      <direction>0 0 -1</direction>
      <attenuation><range>4</range><constant>0.30</constant><linear>0.08</linear><quadratic>0.01</quadratic></attenuation>
      <spot><inner_angle>0.5</inner_angle><outer_angle>0.9</outer_angle><falloff>1.2</falloff></spot>
    </light>
    <!-- Bay lights -->
    <light type="point" name="bay_1"><cast_shadows>false</cast_shadows><pose>-5  0 4.5 0 0 0</pose><diffuse>0.60 0.60 0.62 1</diffuse><specular>0.03 0.03 0.03 1</specular><attenuation><range>9</range><constant>0.5</constant><linear>0.07</linear><quadratic>0.008</quadratic></attenuation></light>
    <light type="point" name="bay_2"><cast_shadows>false</cast_shadows><pose>-2  0 4.5 0 0 0</pose><diffuse>0.60 0.60 0.62 1</diffuse><specular>0.03 0.03 0.03 1</specular><attenuation><range>9</range><constant>0.5</constant><linear>0.07</linear><quadratic>0.008</quadratic></attenuation></light>
    <light type="point" name="bay_3"><cast_shadows>false</cast_shadows><pose>1   0 4.5 0 0 0</pose><diffuse>0.60 0.60 0.62 1</diffuse><specular>0.03 0.03 0.03 1</specular><attenuation><range>9</range><constant>0.5</constant><linear>0.07</linear><quadratic>0.008</quadratic></attenuation></light>
    <light type="point" name="bay_4"><cast_shadows>false</cast_shadows><pose>4   0 4.5 0 0 0</pose><diffuse>0.60 0.60 0.62 1</diffuse><specular>0.03 0.03 0.03 1</specular><attenuation><range>9</range><constant>0.5</constant><linear>0.07</linear><quadratic>0.008</quadratic></attenuation></light>
    <light type="point" name="bay_5"><cast_shadows>false</cast_shadows><pose>-2 -3 4.5 0 0 0</pose><diffuse>0.60 0.60 0.62 1</diffuse><specular>0.03 0.03 0.03 1</specular><attenuation><range>9</range><constant>0.5</constant><linear>0.07</linear><quadratic>0.008</quadratic></attenuation></light>
    <light type="point" name="bay_6"><cast_shadows>false</cast_shadows><pose>2.5 -3 4.5 0 0 0</pose><diffuse>0.60 0.60 0.62 1</diffuse><specular>0.03 0.03 0.03 1</specular><attenuation><range>9</range><constant>0.5</constant><linear>0.07</linear><quadratic>0.008</quadratic></attenuation></light>
    <light type="point" name="bay_7"><cast_shadows>false</cast_shadows><pose>-2 -1.5 4.5 0 0 0</pose><diffuse>0.60 0.60 0.62 1</diffuse><specular>0.03 0.03 0.03 1</specular><attenuation><range>9</range><constant>0.5</constant><linear>0.07</linear><quadratic>0.008</quadratic></attenuation></light>

    <!-- ══ FACTORY STRUCTURE ══════════════════════════════════════════ -->
    <model name="factory_floor"><static>true</static>
      <link name="link">
        <collision name="c"><geometry><plane><normal>0 0 1</normal><size>30 30</size></plane></geometry></collision>
        <visual name="v"><geometry><plane><normal>0 0 1</normal><size>30 30</size></plane></geometry>
          <material><ambient>0.52 0.52 0.54 1</ambient><diffuse>0.56 0.56 0.58 1</diffuse><specular>0.10 0.10 0.11 1</specular></material>
        </visual>
      </link>
    </model>

    <model name="wall_N"><static>true</static><pose>0  9 2.5 0 0 0</pose><link name="l">
      <visual name="v"><geometry><box><size>26 0.18 5</size></box></geometry><material><ambient>0.80 0.80 0.80 1</ambient><diffuse>0.84 0.84 0.84 1</diffuse><specular>0.03 0.03 0.03 1</specular></material></visual>
      <collision name="c"><geometry><box><size>26 0.18 5</size></box></geometry></collision>
    </link></model>
    <model name="wall_S"><static>true</static><pose>0 -9 2.5 0 0 0</pose><link name="l">
      <visual name="v"><geometry><box><size>26 0.18 5</size></box></geometry><material><ambient>0.80 0.80 0.80 1</ambient><diffuse>0.84 0.84 0.84 1</diffuse><specular>0.03 0.03 0.03 1</specular></material></visual>
      <collision name="c"><geometry><box><size>26 0.18 5</size></box></geometry></collision>
    </link></model>
    <model name="wall_E"><static>true</static><pose>9 0 2.5 0 0 0</pose><link name="l">
      <visual name="v"><geometry><box><size>0.18 26 5</size></box></geometry><material><ambient>0.80 0.80 0.80 1</ambient><diffuse>0.84 0.84 0.84 1</diffuse><specular>0.03 0.03 0.03 1</specular></material></visual>
      <collision name="c"><geometry><box><size>0.18 26 5</size></box></geometry></collision>
    </link></model>
    <model name="wall_W"><static>true</static><pose>-9 0 2.5 0 0 0</pose><link name="l">
      <visual name="v"><geometry><box><size>0.18 26 5</size></box></geometry><material><ambient>0.80 0.80 0.80 1</ambient><diffuse>0.84 0.84 0.84 1</diffuse><specular>0.03 0.03 0.03 1</specular></material></visual>
      <collision name="c"><geometry><box><size>0.18 26 5</size></box></geometry></collision>
    </link></model>
    <model name="ceiling"><static>true</static><pose>0 0 5.0 0 0 0</pose><link name="l">
      <visual name="v"><geometry><box><size>26 26 0.14</size></box></geometry><material><ambient>0.76 0.76 0.78 1</ambient><diffuse>0.80 0.80 0.82 1</diffuse></material></visual>
    </link></model>

    <!-- Trusses -->
    <model name="truss_A"><static>true</static><pose>-5 0 4.86 0 0 0</pose><link name="l"><visual name="v"><geometry><box><size>0.11 20 0.11</size></box></geometry><material><ambient>0.32 0.34 0.36 1</ambient><diffuse>0.34 0.36 0.38 1</diffuse><specular>0.30 0.30 0.30 1</specular></material></visual></link></model>
    <model name="truss_B"><static>true</static><pose>-1 0 4.86 0 0 0</pose><link name="l"><visual name="v"><geometry><box><size>0.11 20 0.11</size></box></geometry><material><ambient>0.32 0.34 0.36 1</ambient><diffuse>0.34 0.36 0.38 1</diffuse><specular>0.30 0.30 0.30 1</specular></material></visual></link></model>
    <model name="truss_C"><static>true</static><pose>3 0 4.86 0 0 0</pose><link name="l"><visual name="v"><geometry><box><size>0.11 20 0.11</size></box></geometry><material><ambient>0.32 0.34 0.36 1</ambient><diffuse>0.34 0.36 0.38 1</diffuse><specular>0.30 0.30 0.30 1</specular></material></visual></link></model>

    <!-- Ceiling fixtures -->
    <model name="fix_1"><static>true</static><pose>-5  0 4.73 0 0 0</pose><link name="l"><visual name="v"><geometry><box><size>1.1 0.13 0.05</size></box></geometry><material><ambient>0.88 0.88 0.84 1</ambient><diffuse>0.92 0.92 0.88 1</diffuse><emissive>0.22 0.22 0.20 1</emissive></material></visual></link></model>
    <model name="fix_2"><static>true</static><pose>-2  0 4.73 0 0 0</pose><link name="l"><visual name="v"><geometry><box><size>1.1 0.13 0.05</size></box></geometry><material><ambient>0.88 0.88 0.84 1</ambient><diffuse>0.92 0.92 0.88 1</diffuse><emissive>0.22 0.22 0.20 1</emissive></material></visual></link></model>
    <model name="fix_3"><static>true</static><pose>1   0 4.73 0 0 0</pose><link name="l"><visual name="v"><geometry><box><size>1.1 0.13 0.05</size></box></geometry><material><ambient>0.88 0.88 0.84 1</ambient><diffuse>0.92 0.92 0.88 1</diffuse><emissive>0.22 0.22 0.20 1</emissive></material></visual></link></model>
    <model name="fix_4"><static>true</static><pose>4   0 4.73 0 0 0</pose><link name="l"><visual name="v"><geometry><box><size>1.1 0.13 0.05</size></box></geometry><material><ambient>0.88 0.88 0.84 1</ambient><diffuse>0.92 0.92 0.88 1</diffuse><emissive>0.22 0.22 0.20 1</emissive></material></visual></link></model>
    <model name="fix_5"><static>true</static><pose>-2 -3 4.73 0 0 0</pose><link name="l"><visual name="v"><geometry><box><size>1.1 0.13 0.05</size></box></geometry><material><ambient>0.88 0.88 0.84 1</ambient><diffuse>0.92 0.92 0.88 1</diffuse><emissive>0.22 0.22 0.20 1</emissive></material></visual></link></model>
    <model name="fix_6"><static>true</static><pose>2.5 -3 4.73 0 0 0</pose><link name="l"><visual name="v"><geometry><box><size>1.1 0.13 0.05</size></box></geometry><material><ambient>0.88 0.88 0.84 1</ambient><diffuse>0.92 0.92 0.88 1</diffuse><emissive>0.22 0.22 0.20 1</emissive></material></visual></link></model>

    <!-- ══════════════════════════════════════════════════════════════
         MATERIAL DEFINITIONS (reused via inline — consistent palette)

         Steel chassis:     ambient 0.28 0.30 0.32 / diffuse 0.30 0.32 0.34 / spec 0.22
         Belt rubber dark:  ambient 0.05 0.05 0.05 / diffuse 0.06 0.06 0.07 / spec 0.08
         Aluminium bright:  ambient 0.52 0.54 0.56 / diffuse 0.56 0.58 0.60 / spec 0.35
         Safety yellow:     ambient 0.70 0.58 0.02 / diffuse 0.76 0.64 0.02 / spec 0.18
         Green rail:        ambient 0.08 0.42 0.08 / diffuse 0.10 0.46 0.10 / spec 0.10
         Red rail:          ambient 0.48 0.08 0.06 / diffuse 0.54 0.10 0.07 / spec 0.14
         Dark roller:       ambient 0.32 0.34 0.36 / diffuse 0.36 0.38 0.40 / spec 0.42
    ══════════════════════════════════════════════════════════════ -->

    <!-- ═══════════════════════════════════════════════════════════════
         ZONE 1 — INPUT BUFFER BELT   X=-6.5→-3.0   Y=0
    ══════════════════════════════════════════════════════════════ -->

    <!-- Legs -->
    <model name="ib_l1"><static>true</static><pose>-5.8  0.22 0.40 0 0 0</pose><link name="l"><visual name="v"><geometry><cylinder><radius>0.038</radius><length>0.82</length></cylinder></geometry><material><ambient>0.52 0.54 0.56 1</ambient><diffuse>0.56 0.58 0.60 1</diffuse><specular>0.35 0.35 0.35 1</specular></material></visual><collision name="c"><geometry><cylinder><radius>0.038</radius><length>0.82</length></cylinder></geometry></collision></link></model>
    <model name="ib_l2"><static>true</static><pose>-5.8 -0.22 0.40 0 0 0</pose><link name="l"><visual name="v"><geometry><cylinder><radius>0.038</radius><length>0.82</length></cylinder></geometry><material><ambient>0.52 0.54 0.56 1</ambient><diffuse>0.56 0.58 0.60 1</diffuse><specular>0.35 0.35 0.35 1</specular></material></visual><collision name="c"><geometry><cylinder><radius>0.038</radius><length>0.82</length></cylinder></geometry></collision></link></model>
    <model name="ib_l3"><static>true</static><pose>-4.2  0.22 0.40 0 0 0</pose><link name="l"><visual name="v"><geometry><cylinder><radius>0.038</radius><length>0.82</length></cylinder></geometry><material><ambient>0.52 0.54 0.56 1</ambient><diffuse>0.56 0.58 0.60 1</diffuse><specular>0.35 0.35 0.35 1</specular></material></visual><collision name="c"><geometry><cylinder><radius>0.038</radius><length>0.82</length></cylinder></geometry></collision></link></model>
    <model name="ib_l4"><static>true</static><pose>-4.2 -0.22 0.40 0 0 0</pose><link name="l"><visual name="v"><geometry><cylinder><radius>0.038</radius><length>0.82</length></cylinder></geometry><material><ambient>0.52 0.54 0.56 1</ambient><diffuse>0.56 0.58 0.60 1</diffuse><specular>0.35 0.35 0.35 1</specular></material></visual><collision name="c"><geometry><cylinder><radius>0.038</radius><length>0.82</length></cylinder></geometry></collision></link></model>

    <model name="input_belt"><static>true</static><pose>-4.75 0 0 0 0 0</pose>
      <link name="chassis"><pose>0 0 0.768 0 0 0</pose>
        <visual name="v"><geometry><box><size>3.5 0.50 0.062</size></box></geometry><material><ambient>0.28 0.30 0.32 1</ambient><diffuse>0.30 0.32 0.34 1</diffuse><specular>0.22 0.22 0.22 1</specular></material></visual>
        <collision name="c"><geometry><box><size>3.5 0.50 0.062</size></box></geometry></collision>
      </link>
      <link name="belt"><pose>0 0 0.820 0 0 0</pose>
        <visual name="v"><geometry><box><size>3.5 0.42 0.012</size></box></geometry><material><ambient>0.05 0.05 0.05 1</ambient><diffuse>0.06 0.06 0.07 1</diffuse><specular>0.08 0.08 0.08 1</specular></material></visual>
        <collision name="c"><geometry><box><size>3.5 0.42 0.012</size></box></geometry><surface><friction><ode><mu>1.2</mu><mu2>1.2</mu2></ode></friction></surface></collision>
        <inertial><mass>15</mass></inertial>
      </link>
      <link name="rl"><pose>0  0.236 0.870 0 0 0</pose>
        <visual name="v"><geometry><box><size>3.5 0.018 0.062</size></box></geometry><material><ambient>0.70 0.58 0.02 1</ambient><diffuse>0.76 0.64 0.02 1</diffuse><specular>0.18 0.15 0.01 1</specular></material></visual>
        <collision name="c"><geometry><box><size>3.5 0.018 0.062</size></box></geometry></collision>
      </link>
      <link name="rr"><pose>0 -0.236 0.870 0 0 0</pose>
        <visual name="v"><geometry><box><size>3.5 0.018 0.062</size></box></geometry><material><ambient>0.70 0.58 0.02 1</ambient><diffuse>0.76 0.64 0.02 1</diffuse><specular>0.18 0.15 0.01 1</specular></material></visual>
        <collision name="c"><geometry><box><size>3.5 0.018 0.062</size></box></geometry></collision>
      </link>
      <link name="ro_in"><pose>-1.75 0 0.820 0 1.5708 0</pose>
        <visual name="v"><geometry><cylinder><radius>0.048</radius><length>0.44</length></cylinder></geometry><material><ambient>0.32 0.34 0.36 1</ambient><diffuse>0.36 0.38 0.40 1</diffuse><specular>0.42 0.42 0.42 1</specular></material></visual>
        <collision name="c"><geometry><cylinder><radius>0.048</radius><length>0.44</length></cylinder></geometry></collision>
      </link>
      <link name="ro_out"><pose>1.75 0 0.820 0 1.5708 0</pose>
        <visual name="v"><geometry><cylinder><radius>0.048</radius><length>0.44</length></cylinder></geometry><material><ambient>0.32 0.34 0.36 1</ambient><diffuse>0.36 0.38 0.40 1</diffuse><specular>0.42 0.42 0.42 1</specular></material></visual>
        <collision name="c"><geometry><cylinder><radius>0.048</radius><length>0.44</length></cylinder></geometry></collision>
      </link>

      <!-- Conveyor belt animation plugin -->
      <plugin filename="gz-sim-conveyor-system" name="gz::sim::systems::Conveyor">
        <link>belt</link>
        <speed>0.10</speed>
        <enabled>true</enabled>
      </plugin>
    </model>

    <!-- Camera 1 over input belt — simple post mount -->
    <model name="cam_mount_input"><static>true</static><pose>-4.75 0 0 0 0 0</pose>
      <link name="post"><pose>0 0.55 1.1 0 0 0</pose>
        <visual name="v"><geometry><cylinder><radius>0.028</radius><length>2.22</length></cylinder></geometry><material><ambient>0.28 0.30 0.32 1</ambient><diffuse>0.30 0.32 0.34 1</diffuse><specular>0.38 0.38 0.38 1</specular></material></visual>
        <collision name="c"><geometry><cylinder><radius>0.028</radius><length>2.22</length></cylinder></geometry></collision>
      </link>
      <link name="arm"><pose>0 0.30 2.18 0 0 0</pose>
        <visual name="v"><geometry><box><size>0.048 0.55 0.048</size></box></geometry><material><ambient>0.28 0.30 0.32 1</ambient><diffuse>0.30 0.32 0.34 1</diffuse><specular>0.38 0.38 0.38 1</specular></material></visual>
        <collision name="c"><geometry><box><size>0.048 0.55 0.048</size></box></geometry></collision>
      </link>
      <link name="camera_link_input"><pose>0 0 1.83 0 1.5708 0</pose>
        <visual name="housing"><geometry><box><size>0.10 0.08 0.065</size></box></geometry><material><ambient>0.10 0.10 0.12 1</ambient><diffuse>0.12 0.12 0.14 1</diffuse><specular>0.50 0.50 0.50 1</specular></material></visual>
        <visual name="lens"><pose>0 0 0.038 0 0 0</pose><geometry><cylinder><radius>0.015</radius><length>0.010</length></cylinder></geometry><material><ambient>0.02 0.04 0.08 1</ambient><diffuse>0.02 0.04 0.08 1</diffuse><specular>1 1 1 1</specular></material></visual>
        <visual name="led_i"><pose>0.046 0.028 0.035 0 0 0</pose><geometry><sphere><radius>0.005</radius></sphere></geometry><material><ambient>0 0.75 0.16 1</ambient><diffuse>0 0.80 0.18 1</diffuse><emissive>0 0.36 0.08 1</emissive></material></visual>
        <!-- Input belt monitor sensor -->
        <sensor name="input_camera" type="camera">
          <always_on>1</always_on><update_rate>5</update_rate>
          <topic>/input_camera/image_raw</topic>
          <camera>
            <horizontal_fov>0.85</horizontal_fov>
            <image><width>320</width><height>240</height><format>R8G8B8</format></image>
            <clip><near>0.05</near><far>8.0</far></clip>
          </camera>
        </sensor>
      </link>
    </model>

    <!-- Transfer plate input belt → main belt (at X=-3.0) -->
    <model name="transfer_in"><static>true</static><pose>-3.0 0 0.820 0 0 0</pose>
      <link name="plate">
        <visual name="v"><geometry><box><size>0.06 0.42 0.012</size></box></geometry><material><ambient>0.40 0.42 0.44 1</ambient><diffuse>0.44 0.46 0.48 1</diffuse><specular>0.32 0.32 0.32 1</specular></material></visual>
        <collision name="c"><geometry><box><size>0.06 0.42 0.012</size></box></geometry><surface><friction><ode><mu>0.7</mu><mu2>0.7</mu2></ode></friction></surface></collision>
      </link>
    </model>

    <!-- ═══════════════════════════════════════════════════════════════
         ZONE 2 — MAIN INSPECTION BELT   X=-3.0→2.5   Y=0
    ══════════════════════════════════════════════════════════════ -->
