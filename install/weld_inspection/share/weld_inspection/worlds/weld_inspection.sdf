        <sensor name="good_belt_camera" type="camera">
          <always_on>1</always_on><update_rate>5</update_rate>
          <topic>/good_belt_camera/image_raw</topic>
          <camera>
            <horizontal_fov>0.85</horizontal_fov>
            <image><width>320</width><height>240</height><format>R8G8B8</format></image>
            <clip><near>0.05</near><far>8.0</far></clip>
          </camera>
        </sensor>
      </link>
    </model>

    <!-- Good bin -->
    <model name="good_bin"><static>true</static><pose>5.55 0 0 0 0 0</pose>
      <link name="base"><pose>0 0 0.09 0 0 0</pose>
        <visual name="v"><geometry><box><size>0.72 0.62 0.18</size></box></geometry><material><ambient>0.05 0.22 0.06 1</ambient><diffuse>0.06 0.26 0.07 1</diffuse><specular>0.08 0.12 0.08 1</specular></material></visual>
        <collision name="c"><geometry><box><size>0.72 0.62 0.18</size></box></geometry></collision>
      </link>
      <link name="wb"><pose>0.33 0 0.52 0 0 0</pose>
        <visual name="v"><geometry><box><size>0.06 0.62 0.88</size></box></geometry><material><ambient>0.05 0.22 0.06 1</ambient><diffuse>0.06 0.26 0.07 1</diffuse></material></visual>
        <collision name="c"><geometry><box><size>0.06 0.62 0.88</size></box></geometry></collision>
      </link>
      <link name="wl"><pose>0  0.30 0.52 0 0 0</pose>
        <visual name="v"><geometry><box><size>0.72 0.06 0.88</size></box></geometry><material><ambient>0.05 0.22 0.06 1</ambient><diffuse>0.06 0.26 0.07 1</diffuse></material></visual>
        <collision name="c"><geometry><box><size>0.72 0.06 0.88</size></box></geometry></collision>
      </link>
      <link name="wr"><pose>0 -0.30 0.52 0 0 0</pose>
        <visual name="v"><geometry><box><size>0.72 0.06 0.88</size></box></geometry><material><ambient>0.05 0.22 0.06 1</ambient><diffuse>0.06 0.26 0.07 1</diffuse></material></visual>
        <collision name="c"><geometry><box><size>0.72 0.06 0.88</size></box></geometry></collision>
      </link>
      <link name="glow"><pose>0.35 0 0.96 0 0 0</pose>
        <visual name="v"><geometry><box><size>0.015 0.62 0.052</size></box></geometry><material><ambient>0 0.72 0.15 1</ambient><diffuse>0 0.80 0.18 1</diffuse><emissive>0 0.38 0.08 1</emissive></material></visual>
      </link>
      <link name="sign"><pose>0 0 1.56 0 0 0</pose>
        <visual name="v"><geometry><box><size>0.28 0.11 0.10</size></box></geometry><material><ambient>0 0.36 0.08 1</ambient><diffuse>0 0.42 0.09 1</diffuse><emissive>0 0.16 0.03 1</emissive></material></visual>
      </link>
    </model>

    <!-- ═══════════════════════════════════════════════════════════════
         ZONE 5 — REJECT BELT   X=2.5   Y=0→-5.5   (red)
         Junction plate at X=2.5, Y=0 bridges gap perfectly
    ══════════════════════════════════════════════════════════════ -->

    <!-- Junction plate -->
    <model name="junction"><static>true</static><pose>2.5 -0.24 0.820 0 0 0</pose>
      <link name="plate">
        <visual name="v"><geometry><box><size>0.42 0.52 0.012</size></box></geometry><material><ambient>0.40 0.42 0.44 1</ambient><diffuse>0.44 0.46 0.48 1</diffuse><specular>0.32 0.32 0.32 1</specular></material></visual>
        <collision name="c"><geometry><box><size>0.42 0.52 0.012</size></box></geometry><surface><friction><ode><mu>0.7</mu><mu2>0.7</mu2></ode></friction></surface></collision>
      </link>
      <link name="support"><pose>0 0 -0.04 0 0 0</pose>
        <visual name="v"><geometry><box><size>0.42 0.52 0.068</size></box></geometry><material><ambient>0.34 0.36 0.38 1</ambient><diffuse>0.38 0.40 0.42 1</diffuse><specular>0.22 0.22 0.22 1</specular></material></visual>
        <collision name="c"><geometry><box><size>0.42 0.52 0.068</size></box></geometry></collision>
      </link>
    </model>

    <!-- Reject belt legs -->
    <model name="rb_l1"><static>true</static><pose>2.72 -1.5 0.40 0 0 0</pose><link name="l"><visual name="v"><geometry><cylinder><radius>0.038</radius><length>0.82</length></cylinder></geometry><material><ambient>0.52 0.54 0.56 1</ambient><diffuse>0.56 0.58 0.60 1</diffuse><specular>0.35 0.35 0.35 1</specular></material></visual><collision name="c"><geometry><cylinder><radius>0.038</radius><length>0.82</length></cylinder></geometry></collision></link></model>
    <model name="rb_l2"><static>true</static><pose>2.28 -1.5 0.40 0 0 0</pose><link name="l"><visual name="v"><geometry><cylinder><radius>0.038</radius><length>0.82</length></cylinder></geometry><material><ambient>0.52 0.54 0.56 1</ambient><diffuse>0.56 0.58 0.60 1</diffuse><specular>0.35 0.35 0.35 1</specular></material></visual><collision name="c"><geometry><cylinder><radius>0.038</radius><length>0.82</length></cylinder></geometry></collision></link></model>
    <model name="rb_l3"><static>true</static><pose>2.72 -3.8 0.40 0 0 0</pose><link name="l"><visual name="v"><geometry><cylinder><radius>0.038</radius><length>0.82</length></cylinder></geometry><material><ambient>0.52 0.54 0.56 1</ambient><diffuse>0.56 0.58 0.60 1</diffuse><specular>0.35 0.35 0.35 1</specular></material></visual><collision name="c"><geometry><cylinder><radius>0.038</radius><length>0.82</length></cylinder></geometry></collision></link></model>
    <model name="rb_l4"><static>true</static><pose>2.28 -3.8 0.40 0 0 0</pose><link name="l"><visual name="v"><geometry><cylinder><radius>0.038</radius><length>0.82</length></cylinder></geometry><material><ambient>0.52 0.54 0.56 1</ambient><diffuse>0.56 0.58 0.60 1</diffuse><specular>0.35 0.35 0.35 1</specular></material></visual><collision name="c"><geometry><cylinder><radius>0.038</radius><length>0.82</length></cylinder></geometry></collision></link></model>

    <model name="reject_belt"><static>true</static><pose>2.5 -2.8 0 0 0 0</pose>
      <link name="chassis"><pose>0 0 0.768 0 0 0</pose>
        <visual name="v"><geometry><box><size>0.50 5.5 0.062</size></box></geometry><material><ambient>0.28 0.30 0.32 1</ambient><diffuse>0.30 0.32 0.34 1</diffuse><specular>0.22 0.22 0.22 1</specular></material></visual>
        <collision name="c"><geometry><box><size>0.50 5.5 0.062</size></box></geometry></collision>
      </link>
      <link name="belt"><pose>0 0 0.820 0 0 0</pose>
        <visual name="v"><geometry><box><size>0.42 5.5 0.012</size></box></geometry><material><ambient>0.18 0.03 0.03 1</ambient><diffuse>0.22 0.04 0.04 1</diffuse><specular>0.06 0.03 0.03 1</specular></material></visual>
        <collision name="c"><geometry><box><size>0.42 5.5 0.012</size></box></geometry><surface><friction><ode><mu>1.2</mu><mu2>1.2</mu2></ode></friction></surface></collision>
        <inertial><mass>18</mass></inertial>
      </link>
      <link name="rl"><pose> 0.236 0 0.870 0 0 0</pose>
        <visual name="v"><geometry><box><size>0.018 5.5 0.062</size></box></geometry><material><ambient>0.48 0.08 0.06 1</ambient><diffuse>0.54 0.10 0.07 1</diffuse><specular>0.14 0.05 0.05 1</specular></material></visual>
        <collision name="c"><geometry><box><size>0.018 5.5 0.062</size></box></geometry></collision>
      </link>
      <link name="rr"><pose>-0.236 0 0.870 0 0 0</pose>
        <visual name="v"><geometry><box><size>0.018 5.5 0.062</size></box></geometry><material><ambient>0.48 0.08 0.06 1</ambient><diffuse>0.54 0.10 0.07 1</diffuse><specular>0.14 0.05 0.05 1</specular></material></visual>
        <collision name="c"><geometry><box><size>0.018 5.5 0.062</size></box></geometry></collision>
      </link>
      <link name="ro_t"><pose>0 2.73 0.820 1.5708 0 0</pose>
        <visual name="v"><geometry><cylinder><radius>0.048</radius><length>0.44</length></cylinder></geometry><material><ambient>0.32 0.34 0.36 1</ambient><diffuse>0.36 0.38 0.40 1</diffuse><specular>0.42 0.42 0.42 1</specular></material></visual>
        <collision name="c"><geometry><cylinder><radius>0.048</radius><length>0.44</length></cylinder></geometry></collision>
      </link>
      <link name="ro_b"><pose>0 -2.73 0.820 1.5708 0 0</pose>
        <visual name="v"><geometry><cylinder><radius>0.048</radius><length>0.44</length></cylinder></geometry><material><ambient>0.32 0.34 0.36 1</ambient><diffuse>0.36 0.38 0.40 1</diffuse><specular>0.42 0.42 0.42 1</specular></material></visual>
        <collision name="c"><geometry><cylinder><radius>0.048</radius><length>0.44</length></cylinder></geometry></collision>
      </link>
      <plugin filename="gz-sim-conveyor-system" name="gz::sim::systems::Conveyor">
        <link>belt</link><speed>0.10</speed><enabled>true</enabled>
        <direction>0 -1 0</direction>
      </plugin>
    </model>

    <!-- Camera 4 over reject belt -->
    <model name="cam_mount_reject"><static>true</static><pose>2.5 -2.8 0 0 0 0</pose>
      <link name="post"><pose>0.52 0 1.1 0 0 0</pose>
        <visual name="v"><geometry><cylinder><radius>0.025</radius><length>2.22</length></cylinder></geometry><material><ambient>0.28 0.30 0.32 1</ambient><diffuse>0.30 0.32 0.34 1</diffuse><specular>0.38 0.38 0.38 1</specular></material></visual>
        <collision name="c"><geometry><cylinder><radius>0.025</radius><length>2.22</length></cylinder></geometry></collision>
      </link>
      <link name="arm"><pose>0.26 0 2.18 0 0 0</pose>
        <visual name="v"><geometry><box><size>0.52 0.040 0.040</size></box></geometry><material><ambient>0.28 0.30 0.32 1</ambient><diffuse>0.30 0.32 0.34 1</diffuse><specular>0.38 0.38 0.38 1</specular></material></visual>
        <collision name="c"><geometry><box><size>0.52 0.040 0.040</size></box></geometry></collision>
      </link>
      <link name="camera_link_reject"><pose>0 0 1.83 0 1.5708 0</pose>
        <visual name="housing"><geometry><box><size>0.10 0.08 0.065</size></box></geometry><material><ambient>0.10 0.10 0.12 1</ambient><diffuse>0.12 0.12 0.14 1</diffuse><specular>0.50 0.50 0.50 1</specular></material></visual>
        <visual name="lens"><pose>0 0 0.038 0 0 0</pose><geometry><cylinder><radius>0.014</radius><length>0.010</length></cylinder></geometry><material><ambient>0.02 0.04 0.08 1</ambient><diffuse>0.02 0.04 0.08 1</diffuse><specular>1 1 1 1</specular></material></visual>
        <visual name="led_r"><pose>0.045 0.027 0.033 0 0 0</pose><geometry><sphere><radius>0.005</radius></sphere></geometry><material><ambient>0.75 0.05 0.05 1</ambient><diffuse>0.80 0.06 0.06 1</diffuse><emissive>0.36 0.02 0.02 1</emissive></material></visual>
        <sensor name="reject_belt_camera" type="camera">
          <always_on>1</always_on><update_rate>5</update_rate>
          <topic>/reject_belt_camera/image_raw</topic>
          <camera>
            <horizontal_fov>0.85</horizontal_fov>
            <image><width>320</width><height>240</height><format>R8G8B8</format></image>
            <clip><near>0.05</near><far>8.0</far></clip>
          </camera>
        </sensor>
      </link>
    </model>

    <!-- ═══════════════════════════════════════════════════════════════
         ZONE 6 — REWORK STATION   X=2.5   Y=-6.2
         Robotic welding arm + rework table
    ══════════════════════════════════════════════════════════════ -->

    <!-- Rework worktable -->
    <model name="rework_table"><static>true</static><pose>2.5 -6.2 0 0 0 0</pose>
      <link name="top"><pose>0 0 0.86 0 0 0</pose>
        <visual name="v"><geometry><box><size>0.80 0.80 0.04</size></box></geometry><material><ambient>0.32 0.34 0.36 1</ambient><diffuse>0.36 0.38 0.40 1</diffuse><specular>0.35 0.35 0.35 1</specular></material></visual>
        <collision name="c"><geometry><box><size>0.80 0.80 0.04</size></box></geometry></collision>
      </link>
      <link name="leg1"><pose>-0.35 -0.35 0.43 0 0 0</pose>
        <visual name="v"><geometry><box><size>0.06 0.06 0.86</size></box></geometry><material><ambient>0.28 0.30 0.32 1</ambient><diffuse>0.30 0.32 0.34 1</diffuse><specular>0.22 0.22 0.22 1</specular></material></visual>
        <collision name="c"><geometry><box><size>0.06 0.06 0.86</size></box></geometry></collision>
      </link>
      <link name="leg2"><pose>-0.35  0.35 0.43 0 0 0</pose>
        <visual name="v"><geometry><box><size>0.06 0.06 0.86</size></box></geometry><material><ambient>0.28 0.30 0.32 1</ambient><diffuse>0.30 0.32 0.34 1</diffuse><specular>0.22 0.22 0.22 1</specular></material></visual>
        <collision name="c"><geometry><box><size>0.06 0.06 0.86</size></box></geometry></collision>
      </link>
      <link name="leg3"><pose> 0.35 -0.35 0.43 0 0 0</pose>
        <visual name="v"><geometry><box><size>0.06 0.06 0.86</size></box></geometry><material><ambient>0.28 0.30 0.32 1</ambient><diffuse>0.30 0.32 0.34 1</diffuse><specular>0.22 0.22 0.22 1</specular></material></visual>
        <collision name="c"><geometry><box><size>0.06 0.06 0.86</size></box></geometry></collision>
      </link>
      <link name="leg4"><pose> 0.35  0.35 0.43 0 0 0</pose>
        <visual name="v"><geometry><box><size>0.06 0.06 0.86</size></box></geometry><material><ambient>0.28 0.30 0.32 1</ambient><diffuse>0.30 0.32 0.34 1</diffuse><specular>0.22 0.22 0.22 1</specular></material></visual>
        <collision name="c"><geometry><box><size>0.06 0.06 0.86</size></box></geometry></collision>
      </link>
    </model>

    <!-- ═══════════════════════════════════════════════════════════════
         ROBOTIC WELDING ARM — continuous animated motion
         Base at X=1.5, Y=-6.2   (left of rework table)
         Arm sweeps over the table performing welding motion
    ══════════════════════════════════════════════════════════════ -->
    <model name="robot_arm">
      <pose>1.5 -6.2 0 0 0 0</pose>

      <!-- Robot base -->
      <link name="base">
        <pose>0 0 0.15 0 0 0</pose>
        <inertial><mass>50</mass><inertia><ixx>1</ixx><ixy>0</ixy><ixz>0</ixz><iyy>1</iyy><iyz>0</iyz><izz>1</izz></inertia></inertial>
        <visual name="v"><geometry><cylinder><radius>0.18</radius><length>0.30</length></cylinder></geometry>
          <material><ambient>0.18 0.22 0.28 1</ambient><diffuse>0.20 0.24 0.30 1</diffuse><specular>0.30 0.30 0.30 1</specular></material></visual>
        <collision name="c"><geometry><cylinder><radius>0.18</radius><length>0.30</length></cylinder></geometry></collision>
      </link>

      <!-- Waist joint — rotates around Z -->
      <joint name="waist_joint" type="revolute">
        <parent>base</parent>
        <child>shoulder</child>
        <pose>0 0 0.15 0 0 0</pose>
        <axis>
          <xyz>0 0 1</xyz>
          <limit><lower>-2.0</lower><upper>2.0</upper><effort>500</effort></limit>
          <dynamics><damping>5.0</damping></dynamics>
        </axis>
      </joint>

      <!-- Shoulder link -->
      <link name="shoulder">
        <pose>0 0 0.45 0 0 0</pose>
        <inertial><mass>10</mass><inertia><ixx>0.5</ixx><ixy>0</ixy><ixz>0</ixz><iyy>0.5</iyy><iyz>0</iyz><izz>0.1</izz></inertia></inertial>
        <visual name="hub"><geometry><sphere><radius>0.10</radius></sphere></geometry>
          <material><ambient>0.32 0.34 0.36 1</ambient><diffuse>0.36 0.38 0.40 1</diffuse><specular>0.42 0.42 0.42 1</specular></material></visual>
        <collision name="c"><geometry><sphere><radius>0.10</radius></sphere></geometry></collision>
      </link>

      <!-- Elbow joint — rotates around Y -->
      <joint name="elbow_joint" type="revolute">
        <parent>shoulder</parent>
        <child>upper_arm</child>
        <pose>0 0 0 0 0 0</pose>
        <axis>
          <xyz>0 1 0</xyz>
          <limit><lower>-1.5</lower><upper>0.2</upper><effort>300</effort></limit>
          <dynamics><damping>3.0</damping></dynamics>
        </axis>
      </joint>

      <!-- Upper arm -->
      <link name="upper_arm">
        <pose>0 0 0.75 0 0 0</pose>
        <inertial><mass>6</mass><inertia><ixx>0.2</ixx><ixy>0</ixy><ixz>0</ixz><iyy>0.2</iyy><iyz>0</iyz><izz>0.05</izz></inertia></inertial>
        <visual name="v"><geometry><cylinder><radius>0.055</radius><length>0.60</length></cylinder></geometry>
          <material><ambient>0.32 0.34 0.36 1</ambient><diffuse>0.36 0.38 0.40 1</diffuse><specular>0.42 0.42 0.42 1</specular></material></visual>
        <collision name="c"><geometry><cylinder><radius>0.055</radius><length>0.60</length></cylinder></geometry></collision>
      </link>

      <!-- Wrist joint -->
      <joint name="wrist_joint" type="revolute">
        <parent>upper_arm</parent>
        <child>forearm</child>
        <pose>0 0 0.30 0 0 0</pose>
        <axis>
          <xyz>0 1 0</xyz>
          <limit><lower>-2.0</lower><upper>0.5</upper><effort>150</effort></limit>
          <dynamics><damping>2.0</damping></dynamics>
        </axis>
      </joint>

      <!-- Forearm -->
      <link name="forearm">
        <pose>0 0 1.15 0 0.6 0</pose>
        <inertial><mass>3</mass><inertia><ixx>0.05</ixx><ixy>0</ixy><ixz>0</ixz><iyy>0.05</iyy><iyz>0</iyz><izz>0.02</izz></inertia></inertial>
        <visual name="v"><geometry><cylinder><radius>0.040</radius><length>0.45</length></cylinder></geometry>
          <material><ambient>0.28 0.30 0.32 1</ambient><diffuse>0.30 0.32 0.34 1</diffuse><specular>0.38 0.38 0.38 1</specular></material></visual>
        <collision name="c"><geometry><cylinder><radius>0.040</radius><length>0.45</length></cylinder></geometry></collision>
      </link>

      <!-- Tool joint -->
      <joint name="tool_joint" type="revolute">
        <parent>forearm</parent>
        <child>torch</child>
        <pose>0 0 0.22 0 0 0</pose>
        <axis>
          <xyz>1 0 0</xyz>
          <limit><lower>-1.57</lower><upper>1.57</upper><effort>50</effort></limit>
          <dynamics><damping>1.0</damping></dynamics>
        </axis>
      </joint>

      <!-- Welding torch -->
      <link name="torch">
        <pose>0 0 1.45 0 1.0 0</pose>
        <inertial><mass>0.5</mass><inertia><ixx>0.01</ixx><ixy>0</ixy><ixz>0</ixz><iyy>0.01</iyy><iyz>0</iyz><izz>0.005</izz></inertia></inertial>
        <visual name="body"><geometry><cylinder><radius>0.018</radius><length>0.22</length></cylinder></geometry>
          <material><ambient>0.68 0.52 0.10 1</ambient><diffuse>0.76 0.60 0.12 1</diffuse><specular>0.48 0.38 0.10 1</specular></material></visual>
        <visual name="nozzle"><pose>0 0 0.12 0 0 0</pose><geometry><cylinder><radius>0.010</radius><length>0.05</length></cylinder></geometry>
          <material><ambient>0.20 0.20 0.22 1</ambient><diffuse>0.22 0.22 0.24 1</diffuse><specular>0.55 0.55 0.55 1</specular></material></visual>
        <!-- Arc glow — bright blue-white point at tip -->
        <visual name="arc"><pose>0 0 0.15 0 0 0</pose><geometry><sphere><radius>0.008</radius></sphere></geometry>
          <material><ambient>0.6 0.8 1.0 1</ambient><diffuse>0.7 0.9 1.0 1</diffuse><emissive>0.5 0.7 1.0 1</emissive></material></visual>
        <collision name="c"><geometry><cylinder><radius>0.018</radius><length>0.22</length></cylinder></geometry></collision>
      </link>

      <!-- Animate the arm — waist oscillates -->
      <plugin filename="gz-sim-joint-position-controller-system"
              name="gz::sim::systems::JointPositionController">
        <joint_name>waist_joint</joint_name>
        <topic>/robot_arm/waist_cmd</topic>
        <p_gain>100</p_gain>
        <i_gain>0.1</i_gain>
        <d_gain>10</d_gain>
      </plugin>

      <plugin filename="gz-sim-joint-position-controller-system"
              name="gz::sim::systems::JointPositionController">
        <joint_name>elbow_joint</joint_name>
        <topic>/robot_arm/elbow_cmd</topic>
        <p_gain>80</p_gain>
        <i_gain>0.1</i_gain>
        <d_gain>8</d_gain>
      </plugin>

      <plugin filename="gz-sim-joint-position-controller-system"
              name="gz::sim::systems::JointPositionController">
        <joint_name>wrist_joint</joint_name>
        <topic>/robot_arm/wrist_cmd</topic>
        <p_gain>50</p_gain>
        <i_gain>0.1</i_gain>
        <d_gain>5</d_gain>
      </plugin>
    </model>

    <!-- Welding machine cabinet beside robot -->
    <model name="weld_machine"><static>true</static><pose>0.6 -6.2 0 0 0 0</pose>
      <link name="body"><pose>0 0 0.72 0 0 0</pose>
        <visual name="v"><geometry><box><size>1.0 0.88 1.44</size></box></geometry>
          <material><ambient>0.10 0.18 0.38 1</ambient><diffuse>0.12 0.20 0.42 1</diffuse><specular>0.18 0.24 0.40 1</specular></material></visual>
        <collision name="c"><geometry><box><size>1.0 0.88 1.44</size></box></geometry></collision>
      </link>
      <link name="panel"><pose>0.47 0 0.82 0 0 0</pose>
        <visual name="v"><geometry><box><size>0.034 0.68 0.58</size></box></geometry>
          <material><ambient>0.08 0.10 0.18 1</ambient><diffuse>0.09 0.11 0.20 1</diffuse></material></visual>
      </link>
      <link name="btn_r"><pose>0.50  0.18 0.96 0 0 0</pose>
        <visual name="v"><geometry><cylinder><radius>0.024</radius><length>0.014</length></cylinder></geometry>
          <material><ambient>0.9 0.05 0.05 1</ambient><diffuse>1.0 0.06 0.06 1</diffuse><emissive>0.40 0 0 1</emissive></material></visual>
      </link>
      <link name="btn_g"><pose>0.50 0.08 0.96 0 0 0</pose>
        <visual name="v"><geometry><cylinder><radius>0.024</radius><length>0.014</length></cylinder></geometry>
          <material><ambient>0.05 0.9 0.1 1</ambient><diffuse>0.06 1.0 0.1 1</diffuse><emissive>0 0.40 0 1</emissive></material></visual>
      </link>
      <link name="beacon"><pose>0 0 1.52 0 0 0</pose>
        <visual name="v"><geometry><cylinder><radius>0.048</radius><length>0.088</length></cylinder></geometry>
          <material><ambient>0.78 0.45 0.01 1</ambient><diffuse>0.85 0.52 0.01 1</diffuse><emissive>0.32 0.18 0.01 1</emissive></material></visual>
      </link>
    </model>

    <!-- ═══════════════════════════════════════════════════════════════
         ZONE 7 — RETURN BELT   Y=-1.5   X=2.5→-6.5
         Pieces travel in -X direction (back toward input)
         Same surface height Z=0.820
    ══════════════════════════════════════════════════════════════ -->

    <!-- Vertical transfer at rework → return belt (at X=2.5, Y=-5.5→-1.5) -->
    <model name="rework_to_return_plate"><static>true</static><pose>2.5 -5.72 0.820 0 0 0</pose>
      <link name="l">
        <visual name="v"><geometry><box><size>0.42 0.48 0.012</size></box></geometry><material><ambient>0.40 0.42 0.44 1</ambient><diffuse>0.44 0.46 0.48 1</diffuse><specular>0.32 0.32 0.32 1</specular></material></visual>
        <collision name="c"><geometry><box><size>0.42 0.48 0.012</size></box></geometry><surface><friction><ode><mu>0.7</mu><mu2>0.7</mu2></ode></friction></surface></collision>
      </link>
    </model>

    <!-- Return belt legs -->
    <model name="ret_l1"><static>true</static><pose>-5.0 -1.5 0.40 0 0 0</pose><link name="l"><visual name="v"><geometry><cylinder><radius>0.038</radius><length>0.82</length></cylinder></geometry><material><ambient>0.52 0.54 0.56 1</ambient><diffuse>0.56 0.58 0.60 1</diffuse><specular>0.35 0.35 0.35 1</specular></material></visual><collision name="c"><geometry><cylinder><radius>0.038</radius><length>0.82</length></cylinder></geometry></collision></link></model>
    <model name="ret_l2"><static>true</static><pose>-5.0 -1.72 0.40 0 0 0</pose><link name="l"><visual name="v"><geometry><cylinder><radius>0.038</radius><length>0.82</length></cylinder></geometry><material><ambient>0.52 0.54 0.56 1</ambient><diffuse>0.56 0.58 0.60 1</diffuse><specular>0.35 0.35 0.35 1</specular></material></visual><collision name="c"><geometry><cylinder><radius>0.038</radius><length>0.82</length></cylinder></geometry></collision></link></model>
    <model name="ret_l3"><static>true</static><pose>-2.0 -1.5 0.40 0 0 0</pose><link name="l"><visual name="v"><geometry><cylinder><radius>0.038</radius><length>0.82</length></cylinder></geometry><material><ambient>0.52 0.54 0.56 1</ambient><diffuse>0.56 0.58 0.60 1</diffuse><specular>0.35 0.35 0.35 1</specular></material></visual><collision name="c"><geometry><cylinder><radius>0.038</radius><length>0.82</length></cylinder></geometry></collision></link></model>
    <model name="ret_l4"><static>true</static><pose>-2.0 -1.72 0.40 0 0 0</pose><link name="l"><visual name="v"><geometry><cylinder><radius>0.038</radius><length>0.82</length></cylinder></geometry><material><ambient>0.52 0.54 0.56 1</ambient><diffuse>0.56 0.58 0.60 1</diffuse><specular>0.35 0.35 0.35 1</specular></material></visual><collision name="c"><geometry><cylinder><radius>0.038</radius><length>0.82</length></cylinder></geometry></collision></link></model>

    <model name="return_belt"><static>true</static><pose>-2.0 -1.61 0 0 0 0</pose>
      <link name="chassis"><pose>0 0 0.768 0 0 0</pose>
        <visual name="v"><geometry><box><size>9.0 0.44 0.062</size></box></geometry><material><ambient>0.28 0.30 0.32 1</ambient><diffuse>0.30 0.32 0.34 1</diffuse><specular>0.22 0.22 0.22 1</specular></material></visual>
        <collision name="c"><geometry><box><size>9.0 0.44 0.062</size></box></geometry></collision>
      </link>
      <link name="belt"><pose>0 0 0.820 0 0 0</pose>
        <visual name="v"><geometry><box><size>9.0 0.36 0.012</size></box></geometry><material><ambient>0.05 0.05 0.05 1</ambient><diffuse>0.06 0.06 0.07 1</diffuse><specular>0.08 0.08 0.08 1</specular></material></visual>
        <collision name="c"><geometry><box><size>9.0 0.36 0.012</size></box></geometry><surface><friction><ode><mu>1.2</mu><mu2>1.2</mu2></ode></friction></surface></collision>
        <inertial><mass>20</mass></inertial>
      </link>
      <!-- Blue rails — return/rework path colour coding -->
      <link name="rl"><pose>0  0.204 0.870 0 0 0</pose>
        <visual name="v"><geometry><box><size>9.0 0.016 0.055</size></box></geometry><material><ambient>0.12 0.28 0.55 1</ambient><diffuse>0.14 0.32 0.60 1</diffuse><specular>0.12 0.16 0.28 1</specular></material></visual>
        <collision name="c"><geometry><box><size>9.0 0.016 0.055</size></box></geometry></collision>
      </link>
      <link name="rr"><pose>0 -0.204 0.870 0 0 0</pose>
        <visual name="v"><geometry><box><size>9.0 0.016 0.055</size></box></geometry><material><ambient>0.12 0.28 0.55 1</ambient><diffuse>0.14 0.32 0.60 1</diffuse><specular>0.12 0.16 0.28 1</specular></material></visual>
        <collision name="c"><geometry><box><size>9.0 0.016 0.055</size></box></geometry></collision>
      </link>
      <link name="ro_r"><pose>4.5 0 0.820 0 1.5708 0</pose>
        <visual name="v"><geometry><cylinder><radius>0.048</radius><length>0.38</length></cylinder></geometry><material><ambient>0.32 0.34 0.36 1</ambient><diffuse>0.36 0.38 0.40 1</diffuse><specular>0.42 0.42 0.42 1</specular></material></visual>
        <collision name="c"><geometry><cylinder><radius>0.048</radius><length>0.38</length></cylinder></geometry></collision>
      </link>
      <link name="ro_l"><pose>-4.5 0 0.820 0 1.5708 0</pose>
        <visual name="v"><geometry><cylinder><radius>0.048</radius><length>0.38</length></cylinder></geometry><material><ambient>0.32 0.34 0.36 1</ambient><diffuse>0.36 0.38 0.40 1</diffuse><specular>0.42 0.42 0.42 1</specular></material></visual>
        <collision name="c"><geometry><cylinder><radius>0.048</radius><length>0.38</length></cylinder></geometry></collision>
      </link>
      <plugin filename="gz-sim-conveyor-system" name="gz::sim::systems::Conveyor">
        <link>belt</link><speed>0.10</speed><enabled>true</enabled>
        <direction>-1 0 0</direction>
      </plugin>
    </model>

    <!-- Camera 5 over return belt -->
    <model name="cam_mount_return"><static>true</static><pose>-2.0 -1.61 0 0 0 0</pose>
      <link name="post"><pose>0 0.46 1.1 0 0 0</pose>
        <visual name="v"><geometry><cylinder><radius>0.025</radius><length>2.22</length></cylinder></geometry><material><ambient>0.28 0.30 0.32 1</ambient><diffuse>0.30 0.32 0.34 1</diffuse><specular>0.38 0.38 0.38 1</specular></material></visual>
