    <model name="hz_b"><static>true</static><pose>2.5 0.79 0.001 0 0 0.785</pose><link name="l"><visual name="v"><geometry><box><size>0.80 0.09 0.001</size></box></geometry><material><ambient>0.08 0.08 0.08 1</ambient><diffuse>0.10 0.10 0.10 1</diffuse></material></visual></link></model>
    <model name="hz_c"><static>true</static><pose>2.5 0.93 0.001 0 0 0.785</pose><link name="l"><visual name="v"><geometry><box><size>0.80 0.09 0.001</size></box></geometry><material><ambient>0.72 0.58 0.02 1</ambient><diffuse>0.78 0.64 0.02 1</diffuse></material></visual></link></model>

