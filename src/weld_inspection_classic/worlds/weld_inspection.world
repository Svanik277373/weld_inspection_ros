<?xml version="1.0" ?>
<sdf version="1.6">
  <world name="weld_inspection_world">

    <scene>
      <ambient>0.25 0.25 0.25 1</ambient>
      <background>0.08 0.08 0.08 1</background>
      <shadows>true</shadows>
    </scene>

    <physics type="ode">
      <max_step_size>0.001</max_step_size>
      <real_time_factor>1</real_time_factor>
      <real_time_update_rate>1000</real_time_update_rate>
      <gravity>0 0 -9.81</gravity>
    </physics>

    <plugin name="gazebo_ros_state" filename="libgazebo_ros_state.so">
      <ros><namespace>/gazebo</namespace></ros>
    </plugin>

    <include><uri>model://ground_plane</uri></include>

    <include>
      <uri>model://our_factory_workshop</uri>
      <pose>0 0 0 0 0 0</pose>
    </include>

    <!-- ============================================================ -->
    <!-- FACTORY SHELL: floor, walls, ceiling                         -->
    <!-- Room 10 x 12 x 4 m, conveyor centred at origin              -->
    <!-- ============================================================ -->
    <model name="factory_floor">
      <static>true</static>
      <link name="link">
        <pose>0 0 0.005 0 0 0</pose>
        <visual name="v">
          <geometry><box><size>10 12 0.01</size></box></geometry>
          <material>
            <ambient>0.38 0.38 0.38 1</ambient>
            <diffuse>0.42 0.42 0.42 1</diffuse>
            <specular>0.08 0.08 0.08 1</specular>
          </material>
        </visual>
      </link>
    </model>

    <model name="factory_shell">
      <static>true</static>
      <link name="wall_back">
        <pose>0 -6 2 0 0 0</pose>
        <visual name="v"><geometry><box><size>10 0.2 4</size></box></geometry>
          <material><ambient>0.52 0.52 0.52 1</ambient><diffuse>0.58 0.58 0.58 1</diffuse></material></visual>
        <collision name="c"><geometry><box><size>10 0.2 4</size></box></geometry></collision>
      </link>
      <link name="wall_front">
        <pose>0 6 2 0 0 0</pose>
        <visual name="v"><geometry><box><size>10 0.2 4</size></box></geometry>
          <material><ambient>0.52 0.52 0.52 1</ambient><diffuse>0.58 0.58 0.58 1</diffuse></material></visual>
        <collision name="c"><geometry><box><size>10 0.2 4</size></box></geometry></collision>
      </link>
      <link name="wall_left">
        <pose>-5 0 2 0 0 0</pose>
        <visual name="v"><geometry><box><size>0.2 12 4</size></box></geometry>
          <material><ambient>0.52 0.52 0.52 1</ambient><diffuse>0.58 0.58 0.58 1</diffuse></material></visual>
        <collision name="c"><geometry><box><size>0.2 12 4</size></box></geometry></collision>
      </link>
      <link name="wall_right">
        <pose>5 0 2 0 0 0</pose>
        <visual name="v"><geometry><box><size>0.2 12 4</size></box></geometry>
          <material><ambient>0.52 0.52 0.52 1</ambient><diffuse>0.58 0.58 0.58 1</diffuse></material></visual>
        <collision name="c"><geometry><box><size>0.2 12 4</size></box></geometry></collision>
      </link>
      <link name="ceiling">
        <pose>0 0 4 0 0 0</pose>
        <visual name="v"><geometry><box><size>10 12 0.1</size></box></geometry>
          <material><ambient>0.3 0.3 0.3 1</ambient><diffuse>0.35 0.35 0.35 1</diffuse></material></visual>
      </link>
    </model>

    <!-- ============================================================ -->
    <!-- STRUCTURAL: columns + overhead beams                         -->
    <!-- ============================================================ -->
    <model name="structural_columns">
      <static>true</static>
      <link name="col_nw"><pose>-3 -3 2 0 0 0</pose>
        <visual name="v"><geometry><box><size>0.15 0.15 4</size></box></geometry>
          <material><ambient>0.18 0.18 0.2 1</ambient><diffuse>0.22 0.22 0.25 1</diffuse></material></visual>
      </link>
      <link name="col_ne"><pose>3 -3 2 0 0 0</pose>
