      <static>true</static>
      <link name="f1"><pose>-2 -3 3.72 0 0 0</pose>
        <visual name="v"><geometry><box><size>0.65 0.15 0.07</size></box></geometry>
          <material><ambient>0.95 0.95 0.85 1</ambient><diffuse>1.0 1.0 0.9 1</diffuse></material></visual>
      </link>
