    <light type="point" name="overhead_1">
      <pose>-2 -3 3.6 0 0 0</pose>
      <diffuse>0.88 0.88 0.82 1</diffuse><specular>0.2 0.2 0.2 1</specular>
      <attenuation><range>9</range><constant>0.25</constant><linear>0.04</linear><quadratic>0.004</quadratic></attenuation>
      <cast_shadows>false</cast_shadows>
    </light>
