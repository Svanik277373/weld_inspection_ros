    <!-- Tight spotlight inside the inspection chamber -->
    <light type="spot" name="chamber_spotlight">
      <pose>0 0 1.2 0 0 0</pose>
      <diffuse>1.0 1.0 1.0 1</diffuse>
      <specular>0.3 0.3 0.3 1</specular>
      <direction>0 0 -1</direction>
      <attenuation><range>2.0</range><constant>0.05</constant><linear>0.02</linear><quadratic>0.001</quadratic></attenuation>
      <spot><inner_angle>0.4</inner_angle><outer_angle>0.7</outer_angle><falloff>1.0</falloff></spot>
    </light>

    <!-- ============================================================ -->
    <!-- CONVEYOR BELT                                                 -->
    <!-- ============================================================ -->
    <include>
      <uri>model://conveyor_belt</uri>
      <pose>0 0 0 0 0 0</pose>
    </include>

    <!-- ============================================================ -->
    <!-- INSPECTION CHAMBER (enhanced)                                -->
    <!-- ============================================================ -->
    <model name="detection_chamber">
      <static>true</static>
      <link name="wall_left">
        <pose>-0.25 0 0.86 0 0 0</pose>
        <visual name="v"><geometry><box><size>0.025 0.32 0.22</size></box></geometry>
          <material><ambient>0.15 0.15 0.18 1</ambient><diffuse>0.2 0.2 0.22 1</diffuse></material></visual>
      </link>
      <link name="wall_right">
        <pose>0.25 0 0.86 0 0 0</pose>
        <visual name="v"><geometry><box><size>0.025 0.32 0.22</size></box></geometry>
          <material><ambient>0.15 0.15 0.18 1</ambient><diffuse>0.2 0.2 0.22 1</diffuse></material></visual>
      </link>
      <link name="roof">
        <pose>0 0 0.97 0 0 0</pose>
        <visual name="v"><geometry><box><size>0.52 0.32 0.022</size></box></geometry>
          <material><ambient>0.06 0.06 0.06 1</ambient><diffuse>0.08 0.08 0.08 1</diffuse></material></visual>
      </link>
      <!-- Blue-white LED strips on interior walls -->
      <link name="led_left">
        <pose>-0.236 0 0.86 0 0 0</pose>
        <visual name="v"><geometry><box><size>0.004 0.30 0.18</size></box></geometry>
          <material><ambient>0.6 0.75 1.0 1</ambient><diffuse>0.6 0.75 1.0 1</diffuse><emissive>0.25 0.35 0.55 1</emissive></material></visual>
      </link>
      <link name="led_right">
        <pose>0.236 0 0.86 0 0 0</pose>
        <visual name="v"><geometry><box><size>0.004 0.30 0.18</size></box></geometry>
          <material><ambient>0.6 0.75 1.0 1</ambient><diffuse>0.6 0.75 1.0 1</diffuse><emissive>0.25 0.35 0.55 1</emissive></material></visual>
      </link>
    </model>

    <!-- Camera (unchanged — topic /weld_camera/image_raw) -->
    <model name="camera_model">
      <static>true</static>
      <pose>0 0 0.95 0 1.5708 0</pose>
      <link name="camera_link">
        <sensor name="weld_camera" type="camera">
          <always_on>1</always_on>
          <update_rate>10</update_rate>
          <camera>
            <horizontal_fov>0.80</horizontal_fov>
            <image><width>640</width><height>480</height></image>
            <clip><near>0.01</near><far>3.0</far></clip>
          </camera>
          <plugin name="camera_controller" filename="libgazebo_ros_camera.so">
            <alwaysOn>true</alwaysOn>
            <cameraName>weld_camera</cameraName>
            <frameName>camera_link</frameName>
          </plugin>
        </sensor>
      </link>
    </model>

    <!-- ============================================================ -->
    <!-- HMI STATUS PANEL (pole + screen near sorter)                 -->
    <!-- Indicators show at X=0.385, Y=0.36/0.44 — panel matches     -->
    <!-- ============================================================ -->
