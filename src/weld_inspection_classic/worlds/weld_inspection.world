    <model name="overhead_beams">
      <static>true</static>
      <link name="beam1"><pose>0 -3 3.82 0 0 0</pose>
        <visual name="v"><geometry><box><size>6.3 0.25 0.22</size></box></geometry>
          <material><ambient>0.18 0.18 0.18 1</ambient><diffuse>0.22 0.22 0.22 1</diffuse></material></visual>
      </link>
      <link name="beam2"><pose>0 0 3.82 0 0 0</pose>
        <visual name="v"><geometry><box><size>6.3 0.25 0.22</size></box></geometry>
          <material><ambient>0.18 0.18 0.18 1</ambient><diffuse>0.22 0.22 0.22 1</diffuse></material></visual>
      </link>
